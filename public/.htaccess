<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Allow existing files/directories to load normally
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # SPA fallback for client-side routes like /prebook
  RewriteRule ^ index.html [L]
</IfModule>
