rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email in [
        'pavitr.4444@gmail.com',
        'arpitpathak2408@gmail.com',
        'harshitsb2615@gmail.com'
      ];
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isOwnerOrder() {
      return isSignedIn() && (
        request.auth.uid == resource.data.userId ||
        request.auth.token.email == resource.data.email
      );
    }

    function isOwnerOrderCreate() {
      return isSignedIn() && (
        request.auth.uid == request.resource.data.userId ||
        request.auth.token.email == request.resource.data.email
      );
    }

    function hasValidOrderStatus(status) {
      return status in ['pending', 'confirmed', 'cancelled'];
    }

    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();
    }

    match /adminAccess/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /booking/{orderId} {
      allow read: if isOwnerOrder() || isAdmin();
      allow create: if (isOwnerOrderCreate() || isAdmin()) && hasValidOrderStatus(request.resource.data.status);
      allow update: if (isOwnerOrder() || isAdmin()) && hasValidOrderStatus(request.resource.data.status);
      allow delete: if isAdmin();
    }

    match /prebookings/{orderId} {
      allow read: if isOwnerOrder() || isAdmin();
      allow create: if (isOwnerOrderCreate() || isAdmin()) && hasValidOrderStatus(request.resource.data.status);
      allow update: if (isOwnerOrder() || isAdmin()) && hasValidOrderStatus(request.resource.data.status);
      allow delete: if isAdmin();
    }

    match /payments/{paymentId} {
      allow read: if isAdmin();
      allow write: if false;
    }
  }
}
